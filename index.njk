<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site.brand }} - {{ site.tagline }}</title>
  <meta name="description" content="{{ site.brand }} - {{ site.tagline }}. Join us on byond://{{ site.domain }}:2506.">
  <link rel="icon" type="image/svg+xml" href='data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><rect width="16" height="16" fill="%23000080"/><text x="8" y="12" font-family="MS Sans Serif,Tahoma,sans-serif" font-size="11" font-weight="bold" fill="white" text-anchor="middle">R</text></svg>'>
  <link rel="stylesheet" href="{% webpack 'main.css' %}">
</head>
<body>

<div class="parallax-bg" aria-hidden="true">
  <div class="parallax-layer" data-layer="0"></div>
  <div class="parallax-layer" data-layer="1"></div>
  <div class="parallax-layer" data-layer="2"></div>
  <div class="parallax-layer" data-layer="3"></div>
  <div class="parallax-layer" data-layer="4"></div>
  <div class="parallax-layer" data-layer="5"></div>
  <div class="parallax-layer" data-layer="6"></div>
  <div class="parallax-layer" data-layer="7"></div>
</div>

<main class="window" role="main">
  <div class="title-bar">
    <div class="path">
      <span class="title-icon" aria-hidden="true">&#x1F4BB;</span>
      <span class="title-text">{{ site.brand }} - {{ site.domain }}</span>
    </div>
    <div class="controls" aria-hidden="true">
      <div class="btn">_</div>
      <div class="btn">&#x25A1;</div>
      <div class="btn">&#x2715;</div>
    </div>
  </div>

  <div class="menu-bar">
    <div class="menu-items">
      <span class="menu-item"><u>F</u>ile</span>
      <span class="menu-item"><u>E</u>dit</span>
      <span class="menu-item"><u>V</u>iew</span>
      <span class="menu-item"><u>H</u>elp</span>
    </div>
    <div class="summary">{{ site.brand }}</div>
  </div>

  <div class="content">

    <section class="brand">
      <h1 class="brand-title">{{ site.brand }}</h1>
      <p class="brand-tagline">{{ site.tagline }}</p>
    </section>

    {% set alertGroups = [['info', alerts.info], ['warning', alerts.warning], ['danger', alerts.danger]] %}
    {% set hasAlerts = (alerts.info|length) + (alerts.warning|length) + (alerts.danger|length) %}
    {% if hasAlerts %}
      <section class="alerts" id="alerts">
        {% for group in alertGroups %}
          {% set type = group[0] %}
          {% for msg in group[1] %}
            <div class="alert alert-{{ type }}" id="alert-{{ loop.index }}-{{ type }}">
              <span class="alert-text">{{ msg.message | safe }}</span>
              {% if msg.dismissible %}
                <button class="dismiss" type="button" aria-label="Dismiss">&#x2715;</button>
              {% endif %}
            </div>
          {% endfor %}
        {% endfor %}
      </section>
    {% endif %}

    <section class="about" id="about">
      <h2 class="section-title">README.txt</h2>
      <div class="text-box">
        <p><strong>Space Station 13</strong> is a paranoia-laden round-based roleplaying game set on a metal death trap masquerading as a space station. {{ site.brand }} is a fork focused on a refreshed experience.</p>
        <p>To join you need the BYOND client. Download it, then connect to <code>{{ site.byond_url }}</code>.</p>
        <div class="button-row">
          <a class="pda-button" href="https://www.byond.com/download/" target="_blank" rel="noreferrer noopener">Get BYOND</a>
          <a class="pda-button" href="{{ site.byond_url }}">Join Server</a>
          <a class="pda-button" href="https://github.com/tgstation/tgstation/blob/master/.github/guides/RUNNING_A_SERVER.md" target="_blank" rel="noreferrer noopener">Host a Server</a>
        </div>
      </div>
    </section>

    <section class="servers" id="servers">
      <h2 class="section-title">SERVERS.DAT</h2>
      <div class="gamebanners" data-status-endpoint="{{ site.status_endpoint }}" data-poll-interval="{{ site.poll_interval_ms }}">
        {% for server in servers %}
          <a class="gamebanner loading" id="{{ server.identifier }}" data-server="{{ server.identifier }}" href="byond://{{ server.public_address }}">
            <div class="banner-head">
              <span class="banner-name">{{ server.name }}</span>
              <span class="banner-address">{{ server.public_address }}</span>
            </div>
            <div class="banner-body">
              <span class="version">Loading...</span>
              <span class="map">&nbsp;</span>
              <span class="status">&nbsp;</span>
              <span class="revision">&nbsp;</span>
            </div>
          </a>
        {% endfor %}
      </div>
    </section>

    <section class="navpad" id="links">
      <h2 class="section-title">SHORTCUTS</h2>
      <nav class="nav-grid" aria-label="Site links">
        {% for item in nav %}
          <a class="nav-tile pda-button" href="{{ item.url }}"{% if item.url[0:4] == "http" %} target="_blank" rel="noreferrer noopener"{% endif %}>
            <span class="nav-icon" aria-hidden="true">{{ item.icon }}</span>
            <span class="nav-label">{{ item.label }}</span>
          </a>
        {% endfor %}
      </nav>
    </section>

  </div>

  <div class="status-bar">
    <div class="status-left">Connected to <strong>{{ site.domain }}</strong></div>
    <div class="status-right"><span class="status-dot offline" aria-hidden="true"></span><span class="playercount">checking...</span></div>
  </div>
</main>

<footer class="page-footer">
  <a href="{{ site.github_repo }}" target="_blank" rel="noreferrer noopener">Source</a>
  <span>&middot;</span>
  <span>Built {% currentBuildDate %}</span>
</footer>

<script defer src="{% webpack 'js/main.js' %}"></script>
<script defer src="{% webpack 'js/parallax.js' %}"></script>
<script defer src="{% webpack 'js/gamebanners.js' %}"></script>
<script defer src="{% webpack 'js/dismiss.js' %}"></script>
</body>
</html>
