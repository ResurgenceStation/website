[Unit]
Description=GitHub webhook listener for reduxstation.com
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=reduxweb
Group=reduxweb
WorkingDirectory=/srv/reduxstation/website
ExecStart=/usr/bin/webhook \
  -hooks /etc/reduxstation/webhook.conf \
  -ip 127.0.0.1 \
  -port 9000 \
  -urlprefix hooks \
  -verbose
Restart=on-failure
RestartSec=5s

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/srv/reduxstation /var/log

[Install]
WantedBy=multi-user.target
