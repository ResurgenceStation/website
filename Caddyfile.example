reduxstation.com, www.reduxstation.com {
    # Serve the built site. The redeploy script writes here in place.
    root * /srv/reduxstation/website/_site
    file_server
    encode gzip zstd

    # Forward GitHub webhook traffic to the local webhook daemon.
    # adnanh/webhook listens on 127.0.0.1:9000 with -urlprefix hooks, so the
    # public path /hooks/redeploy-website maps to the "redeploy-website" hook id.
    handle_path /hooks/* {
        reverse_proxy 127.0.0.1:9000
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        ?Cache-Control "public, max-age=300"
    }

    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"
}
